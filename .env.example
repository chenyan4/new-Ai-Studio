# ============================================
# new-Ai-Studio 云服务器部署 - 环境变量示例
# ============================================
# 使用步骤：
#   1. 复制为 .env：  cp .env.example .env
#   2. 按实际环境修改下面各项（至少改 JWT_SECRET_KEY、ALGO_SIDE_BASE_URL）
#   3. 启动前加载：  set -a && source .env && set +a && ./start.sh
#      或单独导出：  export $(grep -v '^#' .env | xargs) && ./start.sh
# 注意：.env 含敏感信息，不要提交到 Git（已加入 .gitignore）
# ============================================

# ---------- 后端服务 ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=7860

# ---------- 算法侧服务（视频/图生等接口） ----------
ALGO_SIDE_BASE_URL=http://127.0.0.1:9001

# ---------- ComfyUI 实例（文生图等本地推理，逗号分隔多实例） ----------
COMFYUI_INSTANCES=127.0.0.1:8188

# ---------- 视频上传目录（算法侧需能读取，同机可留空用默认） ----------
# VIDEO_UPLOAD_DIR=/data/uploaded_video

# ---------- 数据库（留空则使用项目内 sqlite） ----------
# DATABASE_URL=sqlite:///./server/database.db

# ---------- JWT 认证（生产环境务必修改） ----------
JWT_SECRET_KEY=your-super-secret-jwt-key
